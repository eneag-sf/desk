#!/usr/bin/env node
// Publish a local HTML file as a password-protected page on GitHub Pages.
//
//   bin/publish <input.html> <slug> [--password <pw>]
//
// - Encrypts the file with ONE friendly, memorable password shared across ALL
//   your pages — so you (and colleagues) only ever remember a single password.
//   Set your own with --password "your phrase"; otherwise a memorable word-style
//   password is generated the first time and reused everywhere after.
// - Writes the encrypted page to docs/<slug>.html, commits, and pushes.
// - Prints the shareable link and the password.
import { webcrypto as crypto } from 'node:crypto';
import { readFileSync, writeFileSync, existsSync, mkdirSync } from 'node:fs';
import { execFileSync } from 'node:child_process';
import { fileURLToPath } from 'node:url';
import { dirname, join, resolve } from 'node:path';
import { encryptHtml } from './lib/encrypt.mjs';

const ROOT = resolve(dirname(fileURLToPath(import.meta.url)), '..');
const SECRETS = join(ROOT, 'work', '.desk', 'passwords.json');

function die(msg) { console.error('\n✗ ' + msg + '\n'); process.exit(1); }

function git(args, opts = {}) {
  // execFileSync returns null when stdio is 'inherit' (output goes to the
  // terminal, not captured), so guard before calling .trim().
  const out = execFileSync('git', args, { cwd: ROOT, encoding: 'utf8', ...opts });
  return out == null ? '' : out.toString().trim();
}

function genFriendly() {
  // Memorable word-style password: adjective-animal-number. Easy to say, share
  // and recall. You'll usually set your own with --password instead.
  const adj = ['amber', 'brave', 'calm', 'swift', 'sunny', 'clever', 'golden',
               'happy', 'lucky', 'bright', 'mighty', 'gentle', 'royal', 'noble'];
  const animal = ['otter', 'falcon', 'tiger', 'heron', 'panda', 'lynx', 'dolphin',
                  'raven', 'koala', 'puma', 'crane', 'seal', 'fox', 'ibex'];
  const r = crypto.getRandomValues(new Uint8Array(3));
  const n = 10 + (r[2] % 90);
  return `${adj[r[0] % adj.length]}-${animal[r[1] % animal.length]}-${n}`;
}

function loadStore() {
  try { return JSON.parse(readFileSync(SECRETS, 'utf8')); } catch { return {}; }
}
function saveStore(store) {
  mkdirSync(dirname(SECRETS), { recursive: true });
  writeFileSync(SECRETS, JSON.stringify(store, null, 2) + '\n');
}

// ── args ────────────────────────────────────────────────────────────
const argv = process.argv.slice(2);
let inputPath, slug, forced;
for (let i = 0; i < argv.length; i++) {
  if (argv[i] === '--password') { forced = argv[++i]; }
  else if (!inputPath) { inputPath = argv[i]; }
  else if (!slug) { slug = argv[i]; }
}
if (!inputPath || !slug) {
  die('usage: bin/publish <input.html> <slug> [--password <pw>]');
}
if (!/^[a-z0-9][a-z0-9-]*$/.test(slug)) {
  die(`slug "${slug}" must be lowercase letters, digits and dashes only`);
}
const absInput = resolve(ROOT, inputPath);
if (!existsSync(absInput)) die(`input file not found: ${inputPath}`);

// ── url + password (reuse > forced > generate) ──────────────────────
const cfg = JSON.parse(readFileSync(join(ROOT, 'desk.config.json'), 'utf8'));
const url = `${cfg.pagesBase}/${slug}.html`;

const store = loadStore();
const HOUSE = '_house';                 // the single shared password for every page
let house = typeof store[HOUSE] === 'string' ? store[HOUSE] : store[HOUSE] && store[HOUSE].password;
let freshPassword = false;
if (forced) { house = forced; }         // --password sets/replaces the shared password
if (!house) { house = genFriendly(); freshPassword = true; }  // friendly default, first time only
store[HOUSE] = house;
const password = house;                 // same memorable password across all pages
store[slug] = { url, password };        // per-page record (kept for reference)
saveStore(store);

// ── encrypt ─────────────────────────────────────────────────────────
const plaintext = readFileSync(absInput, 'utf8');
const wrapper = readFileSync(join(ROOT, 'templates', 'secure-wrapper.html'), 'utf8');
const encrypted = await encryptHtml(plaintext, password, wrapper);
const outPath = join(ROOT, 'docs', `${slug}.html`);
writeFileSync(outPath, encrypted);

// ── commit + push ───────────────────────────────────────────────────
let pushed = false, hasRemote = false;
try {
  git(['add', join('docs', `${slug}.html`)]);
  try { git(['commit', '-m', `publish: ${slug}`]); }
  catch { /* nothing changed since last publish */ }
  try { git(['remote', 'get-url', 'origin'], { stdio: ['pipe', 'pipe', 'ignore'] }); hasRemote = true; }
  catch { hasRemote = false; }
  if (hasRemote) {
    git(['push', '-u', 'origin', 'HEAD'], { stdio: 'inherit' });
    pushed = true;
  }
} catch (e) {
  console.error('git step warning: ' + (e.message || e));
}

// ── report ──────────────────────────────────────────────────────────
console.log('\n✓ Encrypted page written to docs/' + slug + '.html');
console.log('\n  Link:     ' + url);
console.log('  Password: ' + password + (freshPassword
  ? '  (your memorable password — used for every page; save it)'
  : '  (your shared password)'));
if (pushed) {
  console.log('\n  Live in ~1 min (GitHub Pages build). Send the link and password separately.');
} else if (!hasRemote) {
  console.log('\n  Committed locally. Run bin/setup once to connect GitHub, then it goes live.');
}
console.log('');
